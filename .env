# 前端端口号
FRONTENDPORT=
# Convex 端口号(负责游戏引擎、数据库、向量检索与后端逻辑)
CONVEX_PORT=
# 后端服务API端口号(HTTP API的入口)
SITE_PROXY_PORT=
# Convex 的 dashboard
DASHBOARD_PORT=
# 浏览器可访问的 Convex 地址
VITE_CONVEX_URL=
# 外部需要访问内部的 Convex 的路径
CONVEX_CLOUD_ORIGIN=
# 外部需要访问内部的 Convex 的路径: API 方式
CONVEX_SITE_ORIGIN=
# 本地ollama大模型端口号
OLLAMA_PORT=9004
# AI Town 实例名称
INSTANCE_NAME=
# 实例密钥
INSTANCE_SECRET=
# Convex 开发版发布版本标识
CONVEX_RELEASE_VERSION_DEV=
# 用户 Action（AI 代理行为）超时时间
ACTIONS_USER_TIMEOUT_SECS=3000
# 数据库连接字符串（可能用于 Convex 数据持久化或外部数据库集成）
DATABASE_URL=
# 关闭监测
DISABLE_BEACON=false